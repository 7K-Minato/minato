{
  "dashboard": {
    "title": "Minato Overview",
    "tags": ["minato"],
    "timezone": "browser",
    "panels": [
      {
        "id": 1,
        "title": "GameServers by State",
        "type": "stat",
        "targets": [
          {
            "expr": "minato_gameservers",
            "legendFormat": "{{state}}"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0}
      },
      {
        "id": 2,
        "title": "Action Execution Rate",
        "type": "graph",
        "targets": [
          {
            "expr": "rate(minato_action_executions_total[5m])",
            "legendFormat": "{{action}} - {{result}}"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0}
      },
      {
        "id": 3,
        "title": "Agent Unreachable Events",
        "type": "graph",
        "targets": [
          {
            "expr": "rate(minato_agent_unreachable_total[5m])",
            "legendFormat": "{{profile}}"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8}
      },
      {
        "id": 4,
        "title": "Players Online",
        "type": "graph",
        "targets": [
          {
            "expr": "minato_players_online",
            "legendFormat": "{{game}}/{{server}}"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8}
      }
    ],
    "time": {
      "from": "now-1h",
      "to": "now"
    },
    "refresh": "30s"
  }
}
