# Build the control plane binary
FROM golang:1.26.4 AS builder
ARG TARGETOS
ARG TARGETARCH

WORKDIR /workspace
COPY go.mod go.mod
COPY go.sum go.sum
RUN go mod download

COPY . .
RUN CGO_ENABLED=0 GOOS=${TARGETOS:-linux} GOARCH=${TARGETARCH} go build -ldflags='-s -w' -o controlplane ./cmd/controlplane

FROM gcr.io/distroless/static:nonroot
WORKDIR /
COPY --from=builder /workspace/controlplane .
USER 65532:65532

EXPOSE 8080
ENTRYPOINT ["/controlplane"]
